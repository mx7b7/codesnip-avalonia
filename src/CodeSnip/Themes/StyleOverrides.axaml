<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Style Selector="TreeView, ListBox">
		<Setter Property="ScrollViewer.AllowAutoHide" Value="False" />
	</Style>
	<!-- ....................................................................................... -->
	<!-- Alternative: set Theme={StaticResource StaticScrollViewer} in the TreeView ControlTheme -->
	<Style Selector="TreeView /template/ ScrollViewer">
		<Setter Property="Classes.InsetContent" Value="True" />
	</Style>
	<Style Selector="ListBox /template/ ScrollViewer">
		<Setter Property="Classes.InsetContent" Value="True" />
	</Style>
	<Style Selector="TextBox /template/ ScrollViewer">
		<Setter Property="Classes.InsetContent" Value="True" />
	</Style>
	<!-- ......................ProgressBar Thin Style for Code Runner..................... -->
	<Style Selector="ProgressBar:horizontal.thin">
		<Setter Property="MinHeight" Value="4" />
	</Style>
	<!-- ................IconButton Style .......................................... -->
	<Style Selector="Button.IconButton">
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<!-- Hover -->
	<Style Selector="Button.IconButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Opacity" Value="0.7"/>
	</Style>
	<!-- Disabled -->
	<Style Selector="Button.IconButton:disabled">
		<Setter Property="Opacity" Value="0.3"/>
	</Style>
	<!-- Pressed -->
	<Style Selector="Button.IconButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Opacity" Value="0.5"/>
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<!-- ................ToggleIconButton Style .......................................... -->
	<Style Selector="ToggleButton.ToggleIconButton">
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<!-- Hover -->
	<Style Selector="ToggleButton.ToggleIconButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Opacity" Value="0.7"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
	</Style>
	<!-- Disabled -->
	<Style Selector="ToggleButton.ToggleIconButton:disabled">
		<Setter Property="Opacity" Value="0.3"/>
	</Style>
	<!-- Pressed -->
	<Style Selector="ToggleButton.ToggleIconButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Opacity" Value="0.5"/>
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<Style Selector="ToggleButton.ToggleIconButton:checked /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Opacity" Value="0.5"/>
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
	</Style>
	<!--....................................SearchTextBox...........................................-->
	<Style Selector="TextBox.SearchTextBox:pointerover /template/ Border#border">
		<Setter Property="BorderBrush" Value="{DynamicResource HighlightBrush}" />
	</Style>
	<Style Selector="TextBox.SearchTextBox:focus /template/ Border#border">
		<Setter Property="BorderBrush" Value="{DynamicResource HighlightBrush}" />
	</Style>
	<!--.............................................................................................-->


</Styles>
